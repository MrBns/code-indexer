{
  "name": "@mrbns/code-indexer",
  "version": "0.1.1",
  "description": "Generate greppable per-target indexes of every exported symbol in a TypeScript repo, built for AI-agent code navigation.",
  "keywords": [
    "typescript",
    "index",
    "symbols",
    "ai-agents",
    "code-navigation",
    "cli"
  ],
  "author": "MrBns",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrbns/code-indexer.git"
  },
  "homepage": "https://github.com/mrbns/code-indexer#readme",
  "bugs": {
    "url": "https://github.com/mrbns/code-indexer/issues"
  },
  "type": "module",
  "main": "./dist/cli.mjs",
  "bin": {
    "code-indexer": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "ultracite check",
    "check-types": "tsc --noEmit",
    "fix": "ultracite fix",
    "format": "biome format --write",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24.0.0",
    "tsdown": "^0.22.9",
    "ultracite": "7.7.0"
  }
}
