{
  "name": "@mrbns/code-indexer",
  "version": "0.1.0",
  "description": "Generate greppable per-target indexes of every exported symbol in a TypeScript repo, built for AI-agent code navigation.",
  "keywords": [
    "typescript",
    "index",
    "symbols",
    "ai-agents",
    "code-navigation",
    "cli"
  ],
  "author": "MrBns",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrbns/code-indexer.git"
  },
  "homepage": "https://github.com/mrbns/code-indexer#readme",
  "bugs": {
    "url": "https://github.com/mrbns/code-indexer/issues"
  },
  "type": "module",
  "bin": {
    "code-indexer": "./src/cli.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "code-indexer": "./dist/cli.mjs"
    },
    "main": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@universabile/config": "workspace:*",
    "tsdown": "^0.22.9"
  }
}
